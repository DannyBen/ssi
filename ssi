resolve_completion_base_path() {
  local shell="${1:-}"
  local mode="${2:-auto}"
  local data_home

  [[ -n "$shell" ]] || return 1
  mode="$(resolve_completion_mode "$mode")" || return 1

  case "$shell" in
    bash | zsh | fish)
      ;;
    *)
      return 1
      ;;
