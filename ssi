ssi_bootstrap_command() {

  script_version="$version"
  template=$(cat <<'BOOTSTRAP'
#!/usr/bin/env bash
set -euo pipefail

# === Setup SSI ===

echo "Initializing installer..."

# Set up tmp dir where all work is done
tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT
cd "$tmpdir"
export PATH="$tmpdir:$PATH"

# Download ssi if needed
if ! command -v ssi >/dev/null 2>&1 || [ "$(ssi --version 2>/dev/null)" != "@VERSION@" ]; then
  if command -v curl >/dev/null 2>&1; then
    curl -fSsL https://github.com/DannyBen/ssi/releases/download/v@VERSION@/ssi -o ssi
  elif command -v wget >/dev/null 2>&1; then
    wget -nv -O ssi https://github.com/DannyBen/ssi/releases/download/v@VERSION@/ssi
  else
    echo "Error: please install wget or curl, then try again" >&2
    exit 1
  fi
  chmod +x ssi
fi

# === Run ===

# Example installation steps:
# ssi log info "Installing <tool>"
# ssi install bin <url>
# ssi install man <url>
# ssi log info "<tool> --version : $(<tool> --version)"
BOOTSTRAP
  )
  printf "%s\n" "${template//@VERSION@/$script_version}"

}

parse_requirements() {
  local key

  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --version | -v)
        version_command
        exit
        ;;

      --help | -h)
        long_usage=yes
        ssi_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  export SSI_LOG_LEVEL="${SSI_LOG_LEVEL:-info}"
  export SSI_USER_BIN_ROOT="${SSI_USER_BIN_ROOT:-$HOME/.local/bin}"
  export SSI_SYSTEM_BIN_ROOT="${SSI_SYSTEM_BIN_ROOT:-/usr/local/bin}"
  export SSI_USER_MAN_ROOT="${SSI_USER_MAN_ROOT:-${XDG_DATA_HOME:-$HOME/.local/share}/man}"
  export SSI_SYSTEM_MAN_ROOT="${SSI_SYSTEM_MAN_ROOT:-/usr/local/share/man}"
  export SSI_USER_BASH_COMPLETION_ROOT="${SSI_USER_BASH_COMPLETION_ROOT:-${XDG_DATA_HOME:-$HOME/.local/share}/bash-completion/completions}"
  export SSI_SYSTEM_BASH_COMPLETION_ROOT="${SSI_SYSTEM_BASH_COMPLETION_ROOT:-/usr/local/share/bash-completion/completions}"
  export SSI_USER_ZSH_COMPLETION_ROOT="${SSI_USER_ZSH_COMPLETION_ROOT:-${XDG_DATA_HOME:-$HOME/.local/share}/zsh/site-functions}"
  export SSI_SYSTEM_ZSH_COMPLETION_ROOT="${SSI_SYSTEM_ZSH_COMPLETION_ROOT:-/usr/local/share/zsh/site-functions}"
  export SSI_USER_FISH_COMPLETION_ROOT="${SSI_USER_FISH_COMPLETION_ROOT:-${XDG_DATA_HOME:-$HOME/.local/share}/fish/vendor_completions.d}"
  export SSI_SYSTEM_FISH_COMPLETION_ROOT="${SSI_SYSTEM_FISH_COMPLETION_ROOT:-/usr/local/share/fish/vendor_completions.d}"

  if [[ -n "${SSI_LOG_LEVEL:-}" ]] && [[ ! ${SSI_LOG_LEVEL:-} =~ ^(debug|info|warn|error)$ ]]; then
    printf "%s\n" "SSI_LOG_LEVEL environment variable must be one of: debug, info, warn, error" >&2
    exit 1
  fi

  action=${1:-}

  case $action in
    -*) ;;

    install | i | add)
      action="install"
      shift
      ssi_install_parse_requirements "$@"
      shift $#
      ;;

    uninstall | u | rm | remove)
      action="uninstall"
      shift
      ssi_uninstall_parse_requirements "$@"
      shift $#
      ;;

    test | t | check)
      action="test"
      shift
      ssi_test_parse_requirements "$@"
      shift $#
      ;;

    log)
      action="log"
      shift
      ssi_log_parse_requirements "$@"
      shift $#
      ;;

    bootstrap)
      action="bootstrap"
      shift
      ssi_bootstrap_parse_requirements "$@"
      shift $#
      ;;

    "")
      ssi_usage >&2
      exit 1
      ;;

    *)
      printf "invalid command: %s\n" "$action" >&2
      exit 1
      ;;

  esac

  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)

        printf "invalid argument: %s\n" "$key" >&2
        exit 1

        ;;

    esac
  done

}

