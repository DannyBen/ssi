# src/lib/resolve/man_target_from_name.sh
resolve_man_target_from_name() {
  local raw_name="${1:-}"
  local base section filename

  if [[ -z "$raw_name" ]]; then
    fail "Missing man page name"
    return 1
  fi

  base="$(basename "$raw_name")"
  if [[ "$base" =~ \.([A-Za-z0-9]+)$ ]]; then
    section="${BASH_REMATCH[1]}"
    filename="$base"
  else
    section="1"
    filename="${base}.1"
  fi

  printf "%s:%s" "$section" "$filename"
}

# src/lib/resolve/target_name_from_source.sh
resolve_target_name_from_source() {
  local source_input="${1:-}"
  local name=""

  if [[ -z "$source_input" ]]; then
    fail "Missing source input"
    return 1
  fi

  if [[ "$source_input" == "-" ]]; then
    printf ""
    return 0
  fi

  if [[ "$source_input" =~ ^https?:// ]]; then
    name="${source_input##*/}"
