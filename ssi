# src/lib/resolve/target_name_from_source.sh
resolve_target_name_from_source() {
  local source_input="${1:-}"
  local name=""

  if [[ -z "$source_input" ]]; then
    fail "Missing source input"
    return 1
  fi

  if [[ "$source_input" == "-" ]]; then
    printf ""
    return 0
  fi

  if [[ "$source_input" =~ ^https?:// ]]; then
    name="${source_input##*/}"
    name="${name%%\?*}"
    printf "%s" "$name"
    return 0
  fi

  printf "%s" "$(basename "$source_input")"
}

# :command.command_functions
# :command.function
ssi_bin_command() {

  # src/commands/bin.sh
  source_input="${args[source]}"
  explicit_name="${args[--name]:-}"

  mode="$(resolve_bin_mode)" || return 1
  temp_file="$(fetch_source_to_temp_file "$source_input")" || return 1

  if [[ -n "$explicit_name" ]]; then
    target_name="$explicit_name"
  else
    target_name="$(resolve_target_name_from_source "$source_input")" || return 1
  fi

  if [[ -z "$target_name" ]]; then
    fail "Could not determine target name; use --name"
    return 1
  fi

  bin_root="$(resolve_bin_root "$mode")" || return 1
  target_path="${bin_root}/${target_name}"

  install_file "$temp_file" "$target_path" 755 || return 1

  rm -f "$temp_file"
  printf "%s: %s\n" "$(bold installed)" "$target_path"

}

