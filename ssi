ssi_download_command() {

  url="${args[url]}"
  target="${args[--output]:-}"

  if [[ -z "$target" ]]; then
    target="$(source_target_name "$url")" || return 1
    if [[ -z "$target" ]]; then
      fail "Could not determine output file name; use -o FILE or -o -"
      return 1
    fi
  fi

  if [[ "$target" != "-" ]]; then
    dry_run_note
    log info "$(bold "Downloading file"): $target"
  fi

  source_download "$url" "$target" || return 1

  if [[ "$target" != "-" ]]; then
    log info "File downloaded: $target"
  fi

}

ssi_log_command() {

  level="${args[level]}"
  eval "message=(${args[message]})"

  log "$level" "${message[@]}"

}

ssi_bootstrap_command() {

  script_version="$version"
  prepare_section="$(bootstrap_prepare_installer "$script_version")"
  template="$(bootstrap_template "$prepare_section")"
  file="${args[FILE]:-}"

  if [[ -n "$file" ]]; then
    bootstrap_apply_template "$file" "$template" "$prepare_section" || return 1
  else
    printf "%s\n" "$template"
  fi

}

parse_requirements() {
  local key

  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --version | -v)
        version_command
        exit
        ;;

      --help | -h)
        long_usage=yes
        ssi_usage
        exit
        ;;

      --quiet | -q)

        args['--quiet']=1
        shift
        ;;

      *)
        break
        ;;

    esac
  done

  export SSI_LOG_LEVEL="${SSI_LOG_LEVEL:-info}"
  export SSI_USER_BIN_ROOT="${SSI_USER_BIN_ROOT:-$HOME/.local/bin}"
  export SSI_SYSTEM_BIN_ROOT="${SSI_SYSTEM_BIN_ROOT:-/usr/local/bin}"
  export SSI_USER_MAN_ROOT="${SSI_USER_MAN_ROOT:-${XDG_DATA_HOME:-$HOME/.local/share}/man}"
  export SSI_SYSTEM_MAN_ROOT="${SSI_SYSTEM_MAN_ROOT:-/usr/local/share/man}"
  export SSI_USER_BASH_COMPLETION_ROOT="${SSI_USER_BASH_COMPLETION_ROOT:-${XDG_DATA_HOME:-$HOME/.local/share}/bash-completion/completions}"
  export SSI_SYSTEM_BASH_COMPLETION_ROOT="${SSI_SYSTEM_BASH_COMPLETION_ROOT:-/usr/local/share/bash-completion/completions}"
  export SSI_USER_ZSH_COMPLETION_ROOT="${SSI_USER_ZSH_COMPLETION_ROOT:-${XDG_DATA_HOME:-$HOME/.local/share}/zsh/site-functions}"
  export SSI_SYSTEM_ZSH_COMPLETION_ROOT="${SSI_SYSTEM_ZSH_COMPLETION_ROOT:-/usr/local/share/zsh/site-functions}"
  export SSI_USER_FISH_COMPLETION_ROOT="${SSI_USER_FISH_COMPLETION_ROOT:-${XDG_DATA_HOME:-$HOME/.local/share}/fish/vendor_completions.d}"
  export SSI_SYSTEM_FISH_COMPLETION_ROOT="${SSI_SYSTEM_FISH_COMPLETION_ROOT:-/usr/local/share/fish/vendor_completions.d}"

  if [[ -n "${SSI_LOG_LEVEL:-}" ]] && [[ ! ${SSI_LOG_LEVEL:-} =~ ^(debug|info|warn|error)$ ]]; then
    printf "%s\n" "SSI_LOG_LEVEL environment variable must be one of: debug, info, warn, error" >&2
    exit 1
  fi

  action=${1:-}

  case $action in
    -*) ;;

    install | i | add)
      action="install"
      shift
      ssi_install_parse_requirements "$@"
      shift $#
      ;;

    uninstall | u | rm | remove)
      action="uninstall"
      shift
      ssi_uninstall_parse_requirements "$@"
      shift $#
      ;;

    test | t | check)
      action="test"
      shift
      ssi_test_parse_requirements "$@"
      shift $#
      ;;

    download)
      action="download"
      shift
      ssi_download_parse_requirements "$@"
      shift $#
      ;;

    log)
      action="log"
      shift
      ssi_log_parse_requirements "$@"
      shift $#
      ;;

    bootstrap)
      action="bootstrap"
      shift
      ssi_bootstrap_parse_requirements "$@"
      shift $#
      ;;

    "")
      ssi_usage >&2
      exit 1
      ;;

    *)
      printf "invalid command: %s\n" "$action" >&2
      exit 1
      ;;

  esac

  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)

        printf "invalid argument: %s\n" "$key" >&2
        exit 1

        ;;

    esac
  done

}

ssi_install_parse_requirements() {
  local key

  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --help | -h)
        long_usage=yes
        ssi_install_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  action=${1:-}

  case $action in
    -*) ;;

    bin)
      action="bin"
      shift
      ssi_install_bin_parse_requirements "$@"
      shift $#
      ;;

    man)
      action="man"
      shift
      ssi_install_man_parse_requirements "$@"
      shift $#
      ;;

    completion)
      action="completion"
      shift
      ssi_install_completion_parse_requirements "$@"
      shift $#
      ;;

    startup)
      action="startup"
      shift
      ssi_install_startup_parse_requirements "$@"
      shift $#
      ;;

    "")
      ssi_install_usage >&2
      exit 1
      ;;

    *)
      printf "invalid command: %s\n" "$action" >&2
      exit 1
      ;;

  esac

  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)

        printf "invalid argument: %s\n" "$key" >&2
        exit 1

        ;;

    esac
  done

}

ssi_install_bin_parse_requirements() {
  local key

  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --help | -h)
        long_usage=yes
        ssi_install_bin_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  action="install bin"

  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in

      --name)

        if [[ -n ${2+x} ]]; then
          args['--name']="$2"
          shift
          shift
        else
          printf "%s\n" "--name requires an argument: --name NAME" >&2
          exit 1
        fi
        ;;

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)

        if [[ -z ${args['source']+x} ]]; then
          args['source']=$1
          shift
        else
          printf "invalid argument: %s\n" "$key" >&2
          exit 1
        fi

        ;;

    esac
  done

  if [[ -z ${args['source']+x} ]]; then
    printf "missing required argument: SOURCE\nusage: ssi install bin SOURCE [OPTIONS]\n" >&2

    exit 1
  fi

}

ssi_install_man_parse_requirements() {
  local key

  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --help | -h)
        long_usage=yes
        ssi_install_man_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  action="install man"

  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in

      --name)

        if [[ -n ${2+x} ]]; then
          args['--name']="$2"
          shift
          shift
        else
          printf "%s\n" "--name requires an argument: --name NAME" >&2
          exit 1
        fi
        ;;

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)

        if [[ -z ${args['source']+x} ]]; then
          args['source']=$1
          shift
        else
          printf "invalid argument: %s\n" "$key" >&2
          exit 1
        fi

        ;;

    esac
  done

  if [[ -z ${args['source']+x} ]]; then
    printf "missing required argument: SOURCE\nusage: ssi install man SOURCE [OPTIONS]\n" >&2

    exit 1
  fi

}

