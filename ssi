  if [[ "$mode" == "system" ]]; then
    case "$shell" in
      bash)
        if [[ -d "/usr/local/share/bash-completion/completions" ]]; then
          printf "/usr/local/share/bash-completion/completions"
        elif [[ -d "/usr/local/etc/bash_completion.d" ]]; then
          printf "/usr/local/etc/bash_completion.d"
