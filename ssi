before_hook() {
  if [[ "${args[--quiet]:-}" ]]; then
    SSI_QUIET=1
  fi

}

initialize() {
  declare -g version="0.1.8"
  set -eo pipefail

  export SSI_LOG_LEVEL="${SSI_LOG_LEVEL:-info}"
  export SSI_USER_BIN_ROOT="${SSI_USER_BIN_ROOT:-$HOME/.local/bin}"
  export SSI_SYSTEM_BIN_ROOT="${SSI_SYSTEM_BIN_ROOT:-/usr/local/bin}"
  export SSI_USER_MAN_ROOT="${SSI_USER_MAN_ROOT:-${XDG_DATA_HOME:-$HOME/.local/share}/man}"
  export SSI_SYSTEM_MAN_ROOT="${SSI_SYSTEM_MAN_ROOT:-/usr/local/share/man}"
  export SSI_USER_BASH_COMPLETION_ROOT="${SSI_USER_BASH_COMPLETION_ROOT:-${XDG_DATA_HOME:-$HOME/.local/share}/bash-completion/completions}"
  export SSI_SYSTEM_BASH_COMPLETION_ROOT="${SSI_SYSTEM_BASH_COMPLETION_ROOT:-/usr/local/share/bash-completion/completions}"
  export SSI_USER_ZSH_COMPLETION_ROOT="${SSI_USER_ZSH_COMPLETION_ROOT:-${XDG_DATA_HOME:-$HOME/.local/share}/zsh/site-functions}"
  export SSI_SYSTEM_ZSH_COMPLETION_ROOT="${SSI_SYSTEM_ZSH_COMPLETION_ROOT:-/usr/local/share/zsh/site-functions}"
  export SSI_USER_FISH_COMPLETION_ROOT="${SSI_USER_FISH_COMPLETION_ROOT:-${XDG_DATA_HOME:-$HOME/.local/share}/fish/vendor_completions.d}"
  export SSI_SYSTEM_FISH_COMPLETION_ROOT="${SSI_SYSTEM_FISH_COMPLETION_ROOT:-/usr/local/share/fish/vendor_completions.d}"

}

run() {

  declare -g long_usage=''
  declare -g -A args=()
  declare -g -a input=()

  normalize_input "$@"
  parse_requirements "${input[@]}"
  before_hook

  case "$action" in
    "install") ssi_install_command ;;
    "install bin") ssi_install_bin_command ;;
    "install man") ssi_install_man_command ;;
    "install completion") ssi_install_completion_command ;;
    "install startup") ssi_install_startup_command ;;
    "uninstall") ssi_uninstall_command ;;
    "uninstall bin") ssi_uninstall_bin_command ;;
    "uninstall man") ssi_uninstall_man_command ;;
    "uninstall completion") ssi_uninstall_completion_command ;;
    "uninstall startup") ssi_uninstall_startup_command ;;
    "test") ssi_test_command ;;
    "test bin") ssi_test_bin_command ;;
    "test man") ssi_test_man_command ;;
    "test completion") ssi_test_completion_command ;;
    "test startup") ssi_test_startup_command ;;
    "download") ssi_download_command ;;
    "log") ssi_log_command ;;
    "bootstrap") ssi_bootstrap_command ;;
  esac
}

command_line_args=("$@")
initialize
run "${command_line_args[@]}"
