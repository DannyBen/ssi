    esac
  done

  action="test startup"

  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in

      --all | -a)

        if [[ -n "${args['--shell']:-}" ]]; then
          printf "conflicting options: %s cannot be used with %s\n" "$key" "--shell" >&2
          exit 1
        fi

        args['--all']=1
        shift
        ;;

      --shell)

        if [[ -n "${args['--all']:-}" ]]; then
          printf "conflicting options: %s cannot be used with %s\n" "$key" "--all" >&2
          exit 1
        fi

        if [[ -n ${2+x} ]]; then
          args['--shell']="$2"
          shift
          shift
        else
          printf "%s\n" "--shell requires an argument: --shell SHELL" >&2
          exit 1
        fi
        ;;

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)

        if [[ -z ${args['name']+x} ]]; then
          args['name']=$1
          shift
        else
          printf "invalid argument: %s\n" "$key" >&2
          exit 1
        fi

        ;;

    esac
  done

  if [[ -z ${args['name']+x} ]]; then
    printf "missing required argument: NAME\nusage: ssi test startup NAME [OPTIONS]\n" >&2

    exit 1
  fi

  [[ -n ${args['--shell']:-} ]] || args['--shell']="bash"

  if [[ ${args['--shell']:-} ]] && [[ ! ${args['--shell']:-} =~ ^(bash|zsh|fish)$ ]]; then
    printf "%s\n" "--shell must be one of: bash, zsh, fish" >&2
    exit 1
  fi

}

ssi_log_parse_requirements() {
  local key

  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --help | -h)
        long_usage=yes
        ssi_log_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  action="log"

  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)

        escaped="$(printf '%q' "$1")"
        if [[ -z ${args['level']+x} ]]; then
          args['level']="$1"

        elif [[ -z ${args['message']+x} ]]; then
          args['message']="$escaped"
        else
          args['message']="${args['message']} $escaped"

        fi
        shift

        ;;

    esac
  done

  if [[ -z ${args['level']+x} ]]; then
    printf "missing required argument: LEVEL\nusage: ssi log LEVEL MESSAGE...\n" >&2

    exit 1
  fi

  if [[ -z ${args['message']+x} ]]; then
    printf "missing required argument: MESSAGE\nusage: ssi log LEVEL MESSAGE...\n" >&2

    exit 1
  fi

  if [[ -n ${args['level']:-} ]] && [[ ! ${args['level']:-} =~ ^(debug|info|warn|error)$ ]]; then
    printf "%s\n" "level must be one of: debug, info, warn, error" >&2
    exit 1
  fi

}

ssi_bootstrap_parse_requirements() {
  local key

  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --help | -h)
        long_usage=yes
        ssi_bootstrap_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  action="bootstrap"

  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)

        printf "invalid argument: %s\n" "$key" >&2
        exit 1

        ;;

    esac
  done

}

initialize() {
  declare -g version="0.1.4"
  set -eo pipefail

  export SSI_LOG_LEVEL="${SSI_LOG_LEVEL:-info}"
  export SSI_USER_BIN_ROOT="${SSI_USER_BIN_ROOT:-$HOME/.local/bin}"
  export SSI_SYSTEM_BIN_ROOT="${SSI_SYSTEM_BIN_ROOT:-/usr/local/bin}"
  export SSI_USER_MAN_ROOT="${SSI_USER_MAN_ROOT:-${XDG_DATA_HOME:-$HOME/.local/share}/man}"
  export SSI_SYSTEM_MAN_ROOT="${SSI_SYSTEM_MAN_ROOT:-/usr/local/share/man}"
  export SSI_USER_BASH_COMPLETION_ROOT="${SSI_USER_BASH_COMPLETION_ROOT:-${XDG_DATA_HOME:-$HOME/.local/share}/bash-completion/completions}"
  export SSI_SYSTEM_BASH_COMPLETION_ROOT="${SSI_SYSTEM_BASH_COMPLETION_ROOT:-/usr/local/share/bash-completion/completions}"
  export SSI_USER_ZSH_COMPLETION_ROOT="${SSI_USER_ZSH_COMPLETION_ROOT:-${XDG_DATA_HOME:-$HOME/.local/share}/zsh/site-functions}"
  export SSI_SYSTEM_ZSH_COMPLETION_ROOT="${SSI_SYSTEM_ZSH_COMPLETION_ROOT:-/usr/local/share/zsh/site-functions}"
  export SSI_USER_FISH_COMPLETION_ROOT="${SSI_USER_FISH_COMPLETION_ROOT:-${XDG_DATA_HOME:-$HOME/.local/share}/fish/vendor_completions.d}"
  export SSI_SYSTEM_FISH_COMPLETION_ROOT="${SSI_SYSTEM_FISH_COMPLETION_ROOT:-/usr/local/share/fish/vendor_completions.d}"

}

run() {

  declare -g long_usage=''
  declare -g -A args=()
  declare -g -a input=()

  normalize_input "$@"
  parse_requirements "${input[@]}"

  case "$action" in
    "install") ssi_install_command ;;
    "install bin") ssi_install_bin_command ;;
    "install man") ssi_install_man_command ;;
    "install completion") ssi_install_completion_command ;;
    "install startup") ssi_install_startup_command ;;
    "uninstall") ssi_uninstall_command ;;
    "uninstall bin") ssi_uninstall_bin_command ;;
    "uninstall man") ssi_uninstall_man_command ;;
    "uninstall completion") ssi_uninstall_completion_command ;;
    "uninstall startup") ssi_uninstall_startup_command ;;
    "test") ssi_test_command ;;
    "test bin") ssi_test_bin_command ;;
    "test man") ssi_test_man_command ;;
    "test completion") ssi_test_completion_command ;;
    "test startup") ssi_test_startup_command ;;
    "log") ssi_log_command ;;
    "bootstrap") ssi_bootstrap_command ;;
  esac
}

command_line_args=("$@")
initialize
run "${command_line_args[@]}"
