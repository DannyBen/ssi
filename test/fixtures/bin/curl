#!/usr/bin/env bash
if [[ "$1" == "-fsSL" ]]; then
  url="$2"
  dest=""
  for ((i=1; i<=$#; i++)); do
    if [[ "${!i}" == "-o" ]]; then
      j=$((i+1))
      dest="${!j}"
      break
    fi
  done
  if [[ -n "$dest" ]]; then
    printf "downloaded:%s" "$url" > "$dest"
  else
    printf "downloaded:%s" "$url"
  fi
  exit 0
fi
exit 1
